class ContaBancaria:
    def __init__(self, titular, saldo, numero_conta):
        self.titular = titular
        self.saldo = saldo
        self.numero_conta = numero_conta

    def depositar(self, valor):
        self.saldo += valor
        return f"Depósito de R${valor} realizado com sucesso."

    def exibir_dados(self):
        return f"Titular: {self.titular} | Conta: {self.numero_conta} | Saldo: R${self.saldo}"


# Criando três objetos diferentes
conta1 = ContaBancaria("André", 1000, "001")
conta2 = ContaBancaria("Carlos", 500, "002")
conta3 = ContaBancaria("Maria", 2000, "003")

# Utilizando os métodos
print(conta1.exibir_dados())
print(conta2.exibir_dados())
print(conta3.exibir_dados())

print(conta1.depositar(300))
print(conta1.exibir_dados())